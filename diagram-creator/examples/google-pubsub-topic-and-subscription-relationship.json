{
  "diagram": {
    "title": "Pub/Sub Topic and Subscription Relationship",
    "subtitle": "A topic accepts published messages and fans out to independently managed subscriptions",
    "sections": [
      {
        "id": "publishers",
        "title": "Publishers",
        "subtitle": "Applications publish messages into one topic resource",
        "layout": {
          "type": "flow",
          "direction": "horizontal"
        },
        "lanes": [
          {
            "id": "publish_flow",
            "title": "Publish flow",
            "direction": "vertical",
            "groups": [
              {
                "type": "sequential",
                "nodes": ["publisher_app", "pubsub_topic"]
              }
            ]
          }
        ],
        "nodes": [
          { "id": "publisher_app", "label": "Publisher app", "type": "user", "label_position": "top" },
          { "id": "pubsub_topic", "label": "google_pubsub_topic", "type": "process", "highlight": true }
        ],
        "annotations": [
          {
            "text": "The topic resource defines the Pub/Sub topic that producers publish into.",
            "position": "footer"
          }
        ]
      },
      {
        "id": "subscriptions",
        "title": "Subscriptions",
        "subtitle": "Each subscription points at one topic; a topic can have many subscriptions",
        "layout": {
          "type": "flow",
          "direction": "horizontal"
        },
        "lanes": [
          {
            "id": "subscription_rows",
            "title": "Subscription resources",
            "direction": "vertical",
            "groups": [
              {
                "type": "sequential",
                "nodes": ["pull_subscription", "push_subscription"]
              }
            ]
          }
        ],
        "nodes": [
          { "id": "pull_subscription", "label": "Pull subscription", "type": "process", "highlight": true },
          { "id": "push_subscription", "label": "Push subscription", "type": "process" }
        ],
        "annotations": [
          {
            "text": "A google_pubsub_subscription configures ack deadlines, retention, filters, dead-lettering, and delivery mode.",
            "position": "footer"
          }
        ]
      },
      {
        "id": "consumers",
        "title": "Consumers",
        "subtitle": "Pull workers request messages; push subscriptions deliver to endpoints",
        "layout": {
          "type": "flow",
          "direction": "horizontal"
        },
        "lanes": [
          {
            "id": "consumer_rows",
            "title": "Consumer targets",
            "direction": "vertical",
            "groups": [
              {
                "type": "sequential",
                "nodes": ["subscriber_workers", "push_endpoint"]
              }
            ]
          }
        ],
        "nodes": [
          { "id": "subscriber_workers", "label": "Pull workers", "type": "process" },
          { "id": "push_endpoint", "label": "HTTPS push endpoint", "type": "process" }
        ],
        "annotations": [
          {
            "text": "Pull consumers initiate reads from the subscription; push subscriptions deliver messages to the configured HTTPS endpoint.",
            "position": "footer"
          }
        ]
      }
    ],
    "connections": [
      { "from": "publisher_app", "to": "pubsub_topic", "route": "direct" },
      { "from": "pubsub_topic", "to": "pull_subscription", "route": "direct" },
      { "from": "pubsub_topic", "to": "push_subscription", "route": "direct" },
      { "from": "subscriber_workers", "to": "pull_subscription", "route": "direct" },
      { "from": "push_subscription", "to": "push_endpoint", "route": "direct" }
    ]
  }
}
